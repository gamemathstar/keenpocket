APP_NAME=KeenPocket
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=keenpocket
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@keenpocket.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Firebase Cloud Messaging (push notifications)
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json
FIREBASE_PROJECT_ID=

# --- Phone OTP verification (SMS) ---
# Master switch. Ships OFF; turn on only once an SMS provider is configured.
OTP_ENABLED=false
# Provider: log | termii | africastalking | twilio
OTP_PROVIDER=log
OTP_CODE_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
# Provider credentials (only the selected provider's keys are needed; shared with SMS reminders)
TERMII_API_KEY=
TERMII_SENDER_ID=KeenPocket
AT_USERNAME=
AT_API_KEY=
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# --- SMS reminder channel ---
# Second channel for payment reminders (push always sends). SMS costs money → OFF
# by default. Reuses the provider credentials above.
SMS_ENABLED=false
# Defaults to OTP_PROVIDER if unset: log | termii | africastalking | twilio
SMS_PROVIDER=log

# --- Online payments ---
# Master switch. Ships OFF; the manual "mark as Paid" flow is unchanged while false.
PAYMENTS_ENABLED=false
# Provider: log | paystack | flutterwave
PAYMENTS_PROVIDER=log
PAYMENTS_CURRENCY=NGN
PAYMENTS_CALLBACK_URL="${APP_URL}/payments/callback"
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_HASH=

# --- Automated payouts (disbursement) ---
# Sends a collected Adashi pot to the receiver's bank. Ships OFF (moves money OUT).
# Reuses the Paystack/Flutterwave keys above (Transfers product must be enabled).
PAYOUTS_ENABLED=false
# Defaults to PAYMENTS_PROVIDER if unset: log | paystack | flutterwave
PAYOUTS_PROVIDER=log

# --- Identity verification (KYC: BVN/NIN) ---
# Trust gate for transacting with strangers. Ships OFF. When on, the public
# directory only lists KYC-verified organizers (KYC_GATE_DIRECTORY).
KYC_ENABLED=false
# Provider: log (dev, simulates) | dojah
KYC_PROVIDER=log
KYC_GATE_DIRECTORY=true
DOJAH_APP_ID=
DOJAH_SECRET_KEY=

# --- In-app wallet ---
# Internal balance members spend on contributions. Ships OFF (money handling).
# Real funding needs online payments; with PAYMENTS_PROVIDER=log top-ups credit immediately (dev).
WALLET_ENABLED=false

# --- WhatsApp template messages (Meta Cloud API) ---
# Second/third reminder channel. Ships OFF; reminders still go via push/SMS.
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=log
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_TEMPLATE_PAYMENT_REMINDER=payment_reminder

# --- Referral / WhatsApp invite growth loop ---
# Tracking + invite links ship ON (no money moved). Rewards ship OFF.
REFERRALS_ENABLED=true
REFERRAL_REWARD_ENABLED=false
REFERRAL_REWARD_AMOUNT=0
# What qualifies an invitee: register | join (first pocket/adashi join)
REFERRAL_QUALIFY_ON=join
REFERRAL_CODE_LENGTH=7
REFERRAL_INVITE_BASE_URL="${APP_URL}/invite"
REFERRAL_WHATSAPP_MESSAGE="Join me on KeenPocket to save together — pockets & adashi made easy. {link}"
